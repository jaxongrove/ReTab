{
  "manifest_version": 3,
  "name": "Save Tabs to Storage",
  "version": "1.2",
  "description": "Save and load all open tabs from extension's local storage.",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}